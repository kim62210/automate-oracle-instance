# ==========================================================
# OCI 인스턴스 자동 생성 설정 파일
# 이 파일을 oci.env 로 복사한 뒤 값을 채워 사용하세요:
#   cp oci.env.example oci.env
# ==========================================================

# [필수] OCI API Config 파일의 절대 경로
#   - OCI Console > Profile > API Keys 에서 생성한 config 파일
#   - 예) /Users/your_id/.oci/config
OCI_CONFIG=/path/to/your/oci_config

# [필수] Always Free 가용 도메인 (대부분 AD-1)
OCT_FREE_AD=AD-1

# [필수] SSH 공개키 파일 절대 경로 (없으면 자동 생성)
SSH_AUTHORIZED_KEYS_FILE=/path/to/your/id_rsa.pub

# 시도할 리전 (쉼표로 구분, 비우면 OCI_CONFIG 의 region 사용)
#   예) ap-seoul-1,ap-chuncheon-1
OCI_REGIONS=ap-seoul-1

# 인스턴스 표시 이름
DISPLAY_NAME=a1-free-arm

# 셰이프 (ARM: VM.Standard.A1.Flex / AMD: VM.Standard.E2.1.Micro)
OCI_COMPUTE_SHAPE=VM.Standard.A1.Flex

# 두 번째 Micro 인스턴스를 만들 때만 True
SECOND_MICRO_INSTANCE=False

# 재시도 간격 (초)
REQUEST_WAIT_TIME_SECS=60

# 서브넷 OCID (로컬에서 실행 시 필수, 인스턴스 안에서 실행 시 비워둘 수 있음)
OCI_SUBNET_ID=

# 이미지 OCID (비워두면 아래 OS 정보로 자동 탐색)
OCI_IMAGE_ID=
OPERATING_SYSTEM=Canonical Ubuntu
OS_VERSION=24.04

# 공용 IP 자동 할당
ASSIGN_PUBLIC_IP=true

# 부트 볼륨 크기 (GB, 최소 50)
BOOT_VOLUME_SIZE=50

# ==========================================================
# 알림 (선택)
# Discord Webhook URL 을 넣으면 진행 상황과 결과가 Discord 로 전송됩니다.
# 만들기: 서버 설정 > 연동 > 웹후크 > 새 웹후크 > URL 복사
# 비워두면 알림 없이 동작합니다.
# ==========================================================
DISCORD_WEBHOOK=
