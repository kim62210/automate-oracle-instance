# ==========================================================
# OCI 인스턴스 자동 생성 설정 파일
# 이 파일을 oci.env 로 복사한 뒤 값을 채워 사용하세요:
#   cp oci.env.example oci.env
#
# 각 항목 옆 [획득처] 표시를 따라가면 어디서 값을 얻을지 알 수 있어요.
# ==========================================================

# ----------------------------------------------------------
# [필수] OCI API Config 파일의 절대 경로
# ----------------------------------------------------------
# 획득처:
#   1) https://cloud.oracle.com 로그인
#   2) 우측 상단 사람 아이콘 → "내 프로필(My Profile)"
#   3) 좌측 메뉴 "API 키(API Keys)" → "API 키 추가(Add API Key)"
#   4) "개인 키 다운로드(Download Private Key)" 클릭 (.pem 파일)
#   5) "추가(Add)" 클릭 → "구성 파일 미리보기" 내용 복사
#   6) ~/.oci/config 파일에 붙여넣기
# 예) /Users/your_id/.oci/config (macOS), /home/ubuntu/.oci/config (Linux)
OCI_CONFIG=/path/to/your/oci_config

# ----------------------------------------------------------
# [필수] Always Free 가용 도메인 (대부분 AD-1)
# ----------------------------------------------------------
# 획득처:
#   1) OCI Console 좌측 햄버거 → 컴퓨트(Compute) → 인스턴스(Instances)
#   2) "인스턴스 생성(Create Instance)" 클릭 (실제 생성 X)
#   3) "배치(Placement)" 항목의 이름 끝 부분 확인
#      예) xxxx:AP-SEOUL-1-AD-1 → "AD-1"
#   4) 취소(Cancel) 누르고 나오기
OCT_FREE_AD=AD-1

# ----------------------------------------------------------
# [필수] SSH 공개키(.pub) 파일 절대 경로 (없으면 자동 생성)
# ----------------------------------------------------------
# 획득처 (이미 SSH 키가 있다면 기존 파일 경로 사용):
#   ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519_oci -N ""
#   → ~/.ssh/id_ed25519_oci.pub 사용
SSH_AUTHORIZED_KEYS_FILE=/path/to/your/id_ed25519_oci.pub

# ----------------------------------------------------------
# [선택] 시도할 리전 (쉼표로 구분, 여러 리전 순환 시도)
# ----------------------------------------------------------
# 획득처: OCI Console 우측 상단 리전 드롭다운에서 확인
#   주요 리전: ap-seoul-1, ap-chuncheon-1, ap-tokyo-1, us-ashburn-1
#   비우면 OCI_CONFIG 의 region 값을 사용
OCI_REGIONS=ap-seoul-1,ap-chuncheon-1

# ----------------------------------------------------------
# [선택] 인스턴스 표시 이름 (자유롭게 정해도 됨)
# ----------------------------------------------------------
DISPLAY_NAME=a1-free-arm

# ----------------------------------------------------------
# [선택] 셰이프 (서버 종류)
# ----------------------------------------------------------
# 허용값:
#   VM.Standard.A1.Flex      → ARM, 4 OCPU / 24GB RAM (권장)
#   VM.Standard.E2.1.Micro   → AMD, 1 OCPU / 1GB RAM
OCI_COMPUTE_SHAPE=VM.Standard.A1.Flex

# ----------------------------------------------------------
# [선택] 두 번째 Free Tier Micro 인스턴스를 만들 때만 True
# ----------------------------------------------------------
SECOND_MICRO_INSTANCE=False

# ----------------------------------------------------------
# [선택] 재시도 간격 (초). 너무 짧으면 OCI 가 차단할 수 있음.
# ----------------------------------------------------------
REQUEST_WAIT_TIME_SECS=60

# ----------------------------------------------------------
# [선택] 서브넷 OCID
# ----------------------------------------------------------
# - 본인 컴퓨터(로컬)에서 실행할 때는 보통 비워두면 자동 탐색
# - OCI 안의 다른 Micro 인스턴스에서 돌릴 때만 명시 필요
# 획득처:
#   OCI Console → 네트워킹(Networking) → 가상 클라우드 네트워크
#   → VCN 선택 → 서브넷 → 사용할 서브넷의 OCID 복사
OCI_SUBNET_ID=

# ----------------------------------------------------------
# [선택] 이미지 OCID (특정 OS 이미지를 강제 지정할 때)
# ----------------------------------------------------------
# 비우면 아래 OPERATING_SYSTEM + OS_VERSION 으로 자동 탐색
# 획득처: OCI Console → 컴퓨트 → 사용자 정의 이미지 또는 플랫폼 이미지
OCI_IMAGE_ID=
OPERATING_SYSTEM=Canonical Ubuntu
OS_VERSION=24.04

# ----------------------------------------------------------
# [선택] 공용 IP 자동 할당 (true/false)
# ----------------------------------------------------------
ASSIGN_PUBLIC_IP=true

# ----------------------------------------------------------
# [선택] 부트 볼륨 크기 (GB, 최소 50, Free Tier 한도 200GB)
# ----------------------------------------------------------
BOOT_VOLUME_SIZE=50

# ==========================================================
# 알림 (선택)
# ==========================================================

# ----------------------------------------------------------
# Discord Webhook URL (비우면 알림 없이 동작)
# ----------------------------------------------------------
# 획득처:
#   1) Discord 서버 → 서버 설정(Server Settings)
#   2) 연동(Integrations) → 웹후크(Webhooks) → 새 웹후크
#   3) 채널 선택 후 "URL 복사(Copy Webhook URL)" 클릭
DISCORD_WEBHOOK=
