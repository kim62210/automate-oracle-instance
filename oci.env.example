# ==========================================================
# OCI 인스턴스 자동 생성 설정 파일
# 이 파일을 oci.env 로 복사한 뒤 값을 채워 사용하세요:
#   cp oci.env.example oci.env
#
# 각 항목 옆 [획득처] 표시를 따라가면 어디서 값을 얻을지 알 수 있어요.
# ==========================================================

# ----------------------------------------------------------
# [필수] OCI API Config 파일의 경로
# ----------------------------------------------------------
# 기본값은 레포 폴더 안의 ./oci_config (가장 편한 방식, 모든 파일이 한 폴더):
#   - 백업/이동: 레포 폴더 하나만 옮기면 됨
#   - .gitignore 가 자동 제외 (oci_config, *.pem)
#
# 만들기 절차 (README STEP 1, STEP 2 참고):
#   1) OCI Console > 내 프로필 > API 키 > 추가 > Private Key 다운로드
#   2) 다운로드한 .pem 을 ./oci_api_private_key.pem 으로 이동
#   3) ./oci_config 파일 생성 후 "구성 파일 미리보기" 내용 붙여넣기
#   4) ./oci_config 의 key_file 라인을 절대경로로 수정:
#        key_file=$(pwd)/oci_api_private_key.pem  (실제 절대경로로)
#
# 표준 위치(~/.oci/config) 를 쓰고 싶다면 아래 값을 변경하세요.
OCI_CONFIG=./oci_config

# ----------------------------------------------------------
# [필수] Always Free 가용 도메인 (대부분 AD-1)
# ----------------------------------------------------------
# 획득처:
#   1) OCI Console 좌측 햄버거 → 컴퓨트(Compute) → 인스턴스(Instances)
#   2) "인스턴스 생성(Create Instance)" 클릭 (실제 생성 X)
#   3) "배치(Placement)" 항목의 이름 끝 부분 확인
#      예) xxxx:AP-SEOUL-1-AD-1 → "AD-1"
#   4) 취소(Cancel) 누르고 나오기
OCT_FREE_AD=AD-1

# ----------------------------------------------------------
# [기본값 사용 가능] SSH 공개키(.pub) 파일 경로
# ----------------------------------------------------------
# 기본값 경로에 파일이 없으면 스크립트가 RSA 2048 키쌍을 자동 생성합니다:
#   - 공개키: ~/.ssh/oci_auto.pub
#   - 개인키: ~/.ssh/oci_auto      (서버 SSH 접속 시 이 파일 사용)
#
# 이미 본인 SSH 키가 있고 그걸 쓰고 싶다면 아래 경로를 변경하세요.
#   예) SSH_AUTHORIZED_KEYS_FILE=~/.ssh/id_ed25519.pub
#
# 비워두면 main.py 가 같은 기본값(~/.ssh/oci_auto.pub) 으로 폴백합니다.
SSH_AUTHORIZED_KEYS_FILE=~/.ssh/oci_auto.pub

# ----------------------------------------------------------
# [선택] 시도할 리전 (쉼표로 구분, 여러 리전 순환 시도)
# ----------------------------------------------------------
# 획득처: OCI Console 우측 상단 리전 드롭다운에서 확인
#   주요 리전: ap-seoul-1, ap-chuncheon-1, ap-tokyo-1, us-ashburn-1
#   비우면 OCI_CONFIG 의 region 값을 사용
#
# ⚠️ 홈 리전 외에는 먼저 "리전 구독(Subscribe)" 이 필요합니다:
#   OCI Console 우측 상단 리전 드롭다운 → "리전 관리(Manage Regions)"
#   → 원하는 리전의 [Subscribe] 클릭 → 1-2 분 대기 후 사용 가능
OCI_REGIONS=ap-seoul-1,ap-chuncheon-1

# ----------------------------------------------------------
# [선택] 인스턴스 표시 이름 (자유롭게 정해도 됨)
# ----------------------------------------------------------
DISPLAY_NAME=a1-free-arm

# ----------------------------------------------------------
# [선택] 셰이프 (서버 종류)
# ----------------------------------------------------------
# 허용값:
#   VM.Standard.A1.Flex      → ARM, 4 OCPU / 24GB RAM (권장)
#   VM.Standard.E2.1.Micro   → AMD, 1 OCPU / 1GB RAM
OCI_COMPUTE_SHAPE=VM.Standard.A1.Flex

# ----------------------------------------------------------
# [선택] 두 번째 Free Tier Micro 인스턴스를 만들 때만 True
# ----------------------------------------------------------
SECOND_MICRO_INSTANCE=False

# ----------------------------------------------------------
# [선택] 재시도 간격 (초). 권장값 90.
#   - 너무 짧으면 OCI 가 TooManyRequests 로 차단할 수 있음
#   - 60 미만은 비권장
# ----------------------------------------------------------
REQUEST_WAIT_TIME_SECS=90

# ----------------------------------------------------------
# [강력 권장] 서브넷 OCID
# ----------------------------------------------------------
# - 신규 OCI 계정은 VCN(가상 클라우드 네트워크)이 비어있어 자동 탐색이
#   실패합니다. 자동 탐색이 실패하면 해당 리전이 skip 되어 인스턴스
#   생성을 시도조차 못 합니다.
# - 처음 사용한다면 먼저 VCN/Subnet 을 생성해 OCID 를 여기 채우세요.
#
# 신규 VCN 생성 방법:
#   1) OCI Console 햄버거 → 네트워킹(Networking) → 가상 클라우드 네트워크
#   2) "VCN 마법사 시작(Start VCN Wizard)" → "인터넷 연결성을 가진 VCN 생성"
#   3) 이름 입력 후 생성 (CIDR 등은 기본값 그대로)
#
# 서브넷 OCID 복사:
#   OCI Console → 네트워킹 → VCN → 서브넷 → 사용할 서브넷 → OCID 복사
OCI_SUBNET_ID=

# ----------------------------------------------------------
# [선택] 이미지 OCID (특정 OS 이미지를 강제 지정할 때)
# ----------------------------------------------------------
# 비우면 아래 OPERATING_SYSTEM + OS_VERSION 으로 자동 탐색.
# 획득처: OCI Console → 컴퓨트 → 사용자 정의 이미지 또는 플랫폼 이미지
OCI_IMAGE_ID=

# ----------------------------------------------------------
# [조건부 필수] OS 이름과 버전 -- OCI_IMAGE_ID 가 비어있을 때 사실상 필수
# ----------------------------------------------------------
# OCI_IMAGE_ID 가 비어있으면 이 두 값으로 이미지를 자동 탐색합니다.
# 둘 중 하나라도 비거나 오타면 이미지를 못 찾아 해당 리전이 skip 됩니다.
# 정확한 값을 모르겠으면 아래 기본값 그대로 두세요.
OPERATING_SYSTEM="Canonical Ubuntu"
OS_VERSION=24.04

# ----------------------------------------------------------
# [선택] 공용 IP 자동 할당 (true/false)
# ----------------------------------------------------------
ASSIGN_PUBLIC_IP=true

# ----------------------------------------------------------
# [선택] 부트 볼륨 크기 (GB, 최소 50, Free Tier 한도 200GB)
# ----------------------------------------------------------
BOOT_VOLUME_SIZE=50

# ==========================================================
# 알림 (선택)
# ==========================================================

# ----------------------------------------------------------
# Discord Webhook URL (비우면 알림 없이 동작)
# ----------------------------------------------------------
# 획득처:
#   1) Discord 서버 → 서버 설정(Server Settings)
#   2) 연동(Integrations) → 웹후크(Webhooks) → 새 웹후크
#   3) 채널 선택 후 "URL 복사(Copy Webhook URL)" 클릭
DISCORD_WEBHOOK=
