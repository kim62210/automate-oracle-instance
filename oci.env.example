# OCI Configuration
OCI_CONFIG=/path/to/your/oci_config
OCT_FREE_AD=AD-1
# Comma-separated region list (e.g. ap-seoul-1,ap-chuncheon-1)
OCI_REGIONS=ap-seoul-1
DISPLAY_NAME=a1-free-arm
OCI_COMPUTE_SHAPE=VM.Standard.A1.Flex
SECOND_MICRO_INSTANCE=False
REQUEST_WAIT_TIME_SECS=60
SSH_AUTHORIZED_KEYS_FILE=/path/to/your/id_rsa.pub
# OCI Console > Networking > Subnets 에서 확인
OCI_SUBNET_ID=
# 비워두면 OPERATING_SYSTEM + OS_VERSION 으로 자동 탐색
OCI_IMAGE_ID=
OPERATING_SYSTEM=Canonical Ubuntu
OS_VERSION=24.04
ASSIGN_PUBLIC_IP=true
BOOT_VOLUME_SIZE=50

# Gmail (불필요하면 False 유지)
NOTIFY_EMAIL=False
EMAIL=
EMAIL_PASSWORD=

# Discord Webhook (서버 설정 > 연동 > 웹후크 > URL 복사)
DISCORD_WEBHOOK=

# Telegram (optional)
TELEGRAM_TOKEN=
TELEGRAM_USER_ID=
